{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "env": {
    "PATH": "/home/hiroki/.nodenv/versions/22.22.1/bin:/home/hiroki/.local/bin:/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin",
    "CLAUDE_CODE_USE_VERTEX": "1",
    "CLOUD_ML_REGION": "global",
    "ANTHROPIC_VERTEX_PROJECT_ID": "speeda-161813",
    "CLAUDE_CODE_ENABLE_TELEMETRY": "1",
    "OTEL_METRICS_EXPORTER": "otlp",
    "OTEL_EXPORTER_OTLP_ENDPOINT": "https://dev-otel-collector.ub-speeda.com",
    "OTEL_EXPORTER_OTLP_PROTOCOL": "http/protobuf",
    "OTEL_RESOURCE_ATTRIBUTES": "team.member=hiroki.iida@uzabase.com"
  },
  "permissions": {
    "allow": [
      "Bash",
      "WebSearch",
      "WebFetch",
      "Read",
      "Glob",
      "Grep"
    ],
    "deny": [
      "Bash(rm:*)",
      "Bash(rmdir:*)",
      "Bash(sudo:*)",
      "Bash(git push:*)",
      "Bash(git reset --hard:*)",
      "Bash(git clean:*)",
      "Bash(git checkout -- :*)",
      "Bash(git branch -D:*)",
      "Bash(kill:*)",
      "Bash(pkill:*)",
      "Read(**/.env)",
      "Read(**/.env.*)",
      "Read(**/id_rsa*)",
      "Read(**/id_ed25519*)"
    ]
  },
  "model": "claude-fable-5[1m]",
  "hooks": {
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "if command -v osascript >/dev/null 2>&1; then osascript -e 'display notification \"承認待ちです\" with title \"Claude Code\" sound name \"Glass\"'; elif command -v notify-send >/dev/null 2>&1; then notify-send 'Claude Code' '承認待ちです'; fi; true",
            "async": true
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "if command -v osascript >/dev/null 2>&1; then osascript -e 'display notification \"処理が完了しました\" with title \"Claude Code\"'; elif command -v notify-send >/dev/null 2>&1; then notify-send 'Claude Code' '処理が完了しました'; fi; true",
            "async": true
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "command -v jq >/dev/null 2>&1 || exit 0; f=$(jq -r '.tool_input.file_path // empty' 2>/dev/null); case \"$f\" in *.py) ~/.local/bin/uvx ruff format --quiet \"$f\" 2>/dev/null; ~/.local/bin/uvx ruff check --fix --quiet \"$f\" 2>/dev/null;; esac; true",
            "timeout": 30
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "~/.claude/statusline.sh"
  },
  "tui": "fullscreen",
  "theme": "dark",
  "enabledPlugins": {
    "code-review@claude-plugins-official": true,
    "github@claude-plugins-official": true,
    "commit-commands@claude-plugins-official": true,
    "pyright-lsp@claude-plugins-official": true,
    "supabase@claude-plugins-official": true,
    "claude-code-setup@claude-plugins-official": true,
    "agent-sdk-dev@claude-plugins-official": true,
    "Notion@claude-plugins-official": true,
    "plugin-dev@claude-plugins-official": true,
    "slack@claude-plugins-official": true,
    "skill-creator@claude-plugins-official": true,
    "playground@claude-plugins-official": true,
    "sentry@claude-plugins-official": true,
    "huggingface-skills@claude-plugins-official": true,
    "deep-implement@piercelamb-plugins": true,
    "terraform-provider-development@hashicorp": true,
    "terraform-module-generation@hashicorp": true,
    "otel-endpoint-check@uzabase-tools": true,
    "datadog@claude-plugins-official": true
  },
  "extraKnownMarketplaces": {
    "claude-plugins-official": {
      "source": {
        "source": "github",
        "repo": "anthropics/claude-plugins-official"
      }
    },
    "piercelamb-plugins": {
      "source": {
        "source": "github",
        "repo": "piercelamb/deep-implement"
      }
    },
    "hashicorp": {
      "source": {
        "source": "github",
        "repo": "hashicorp/agent-skills"
      }
    },
    "uzabase-tools": {
      "source": {
        "source": "git",
        "url": "git@github.com:uzabase/claude-plugins.git"
      },
      "autoUpdate": true
    }
  },
  "otelHeadersHelper": "$HOME/.claude/custom-script/otel-headers.sh",
  "skipWorkflowUsageWarning": true
}
